#!/usr/bin/env node
"use strict";

const { spawn } = require("child_process");
const { existsSync, lstatSync, readlinkSync } = require("fs");
const { join, dirname, resolve } = require("path");

const PLATFORMS = {
  "darwin-arm64": "etoro-cli-darwin-arm64",
  "darwin-x64": "etoro-cli-darwin-x64",
  "linux-arm64": "etoro-cli-linux-arm64",
  "linux-x64": "etoro-cli-linux-x64",
};

function resolveSymlinks(p) {
  const visited = new Set();
  let current = p;
  while (current && !visited.has(current)) {
    visited.add(current);
    try {
      if (!lstatSync(current).isSymbolicLink()) break;
      current = resolve(dirname(current), readlinkSync(current));
    } catch {
      break;
    }
  }
  return current;
}

function findBinary() {
  const key = `${process.platform}-${process.arch}`;
  const pkg = PLATFORMS[key];

  if (!pkg) {
    console.error(
      `etoro-cli: unsupported platform ${key}\n` +
        `Supported: ${Object.keys(PLATFORMS).join(", ")}`
    );
    process.exit(1);
  }

  const binRel = join("bin", "etoro");

  const searchRoots = [__dirname, process.cwd()];
  try {
    searchRoots.push(dirname(resolveSymlinks(process.argv[1])));
  } catch {}

  try {
    const resolved = require.resolve(`${pkg}/package.json`, {
      paths: searchRoots,
    });
    const binPath = join(dirname(resolved), binRel);
    if (existsSync(binPath)) return binPath;
  } catch {}

  for (const start of searchRoots) {
    let dir = start;
    while (true) {
      const candidate = join(dir, "node_modules", pkg, binRel);
      if (existsSync(candidate)) return candidate;
      const parent = dirname(dir);
      if (parent === dir) break;
      dir = parent;
    }
  }

  console.error(
    `etoro-cli: could not find binary for ${key}\n` +
      `Expected package: ${pkg}\n` +
      `Try: npm install -g etoro-cli`
  );
  process.exit(1);
}

const child = spawn(findBinary(), process.argv.slice(2), {
  stdio: "inherit",
});

child.on("exit", (code, signal) => {
  if (signal) {
    process.kill(process.pid, signal);
  } else {
    process.exit(code ?? 1);
  }
});
